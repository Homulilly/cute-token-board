# ==========================================
# Token Board 环境变量配置文件示例
# ==========================================

# 1. 看板展示设备定义
# ------------------------------------------
# 要在看板展示的设备名称列表（英文逗号分隔）
# 设备名称会自动转换为小写 key 用于默认文件名（如 iPad -> data/token-ipad.json）
# 留空或不设置时不会自动加载任何设备
TOKEN_DEVICES="Mac,Windows,iPad"

# 2. 设备 JSON 数据源映射（可选）
# ------------------------------------------
# 您可以直接从设备名称指定独立的本地相对路径或远程 HTTP 链接
# 仅对 TOKEN_DEVICES 中列出的设备生效
# 某个设备的 URL 留空时，系统将回退查找 "data/token-[设备小写名称].json"
TOKEN_URL_MAC="data/token-mac.json"
TOKEN_URL_WINDOWS="data/token-windows.json"
TOKEN_URL_IPAD="data/token-ipad.json"

# 3. 自定义网页字体配置（可选）
# ------------------------------------------
# 加载字体的 CSS 样式表 CDN 链接（不填默认使用 fonts.loli.net 的 Sniglet 链接）
# 系统会自动从此链接的 family 参数中提取字体族名称（例如从 family=Outfit 中自动解析出 "Outfit" 字体）
FONT_CDN_URL="https://fonts.loli.net/css2?family=Sniglet:wght@400;800&display=swap"

# 字体族名称（可选，仅当系统自动解析错误或需要使用本地已安装字体时，才需配置此项以覆盖）
# FONT_NAME="Sniglet"

# 4. 看板站点名称设置（可选）
# ------------------------------------------
# 自定义看板站点名称（显示在浏览器标题栏与网页主标题，不填默认使用 "Token Board"）
SITE_NAME="Token Board"
