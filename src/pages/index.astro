    <noscript>
      <style>
        .loading-screen {
          display: none;
        }
      </style>
    </noscript>
    <script is:inline define:vars={{ thinkingDelay }}>
      (() => {
        const syncLoadingCenter = () => {
          const viewport = window.visualViewport;
          const centerX = viewport ? viewport.offsetLeft + viewport.width / 2 : window.innerWidth / 2;
          const centerY = viewport ? viewport.offsetTop + viewport.height / 2 : window.innerHeight / 2;
          document.documentElement.style.setProperty("--loading-center-x", `${centerX}px`);
          document.documentElement.style.setProperty("--loading-center-y", `${centerY}px`);
        };

        if (thinkingDelay > 0) {
          syncLoadingCenter();
          window.addEventListener("resize", syncLoadingCenter, { passive: true });
          window.visualViewport?.addEventListener("resize", syncLoadingCenter, { passive: true });
          window.visualViewport?.addEventListener("scroll", syncLoadingCenter, { passive: true });

          window.setTimeout(() => {
            document.body.classList.remove("is-loading");
            document.body.classList.add("is-loaded");
            window.removeEventListener("resize", syncLoadingCenter);
            window.visualViewport?.removeEventListener("resize", syncLoadingCenter);
            window.visualViewport?.removeEventListener("scroll", syncLoadingCenter);
          }, thinkingDelay);
        } else {
          document.body.classList.add("is-loaded");
        }

        const chartPanel = document.querySelector(".chart-panel");
        if (!chartPanel) return;

        const mainBoard = document.querySelector("main.board");
        const curveTitle = chartPanel.querySelector("#curve-title");
        const chartCaption = chartPanel.querySelector("[data-chart-caption]");
        const unitButtons = Array.from(chartPanel.querySelectorAll("[data-unit-trigger]"));
        const rangeButtons = Array.from(chartPanel.querySelectorAll("[data-chart-trigger]"));
        const chartSvgs = Array.from(chartPanel.querySelectorAll("[data-chart-range]"));

        const weeklyRangeSwitch = chartPanel.querySelector(".weekly-ranges");
        const dailyRangeSwitch = chartPanel.querySelector(".daily-ranges");
        const monthlyRangeSwitch = chartPanel.querySelector(".monthly-ranges");

        let currentUnit = "daily";
        let currentRange = "1m";

        const activateChart = (range, unit) => {
          currentRange = range;
          currentUnit = unit;

          // Toggle layout view class
          if (mainBoard) {
            mainBoard.classList.toggle("view-daily", unit === "daily");
          }

          // 1. Update Title text
          if (curveTitle) {
            curveTitle.textContent = unit === "weekly" 
              ? "Weekly Usage Curve" 
              : unit === "monthly" 
                ? "Monthly Usage Curve" 
                : "Daily Usage Curve";
          }

          // 2. Toggle range switch containers visibility
          if (weeklyRangeSwitch && dailyRangeSwitch && monthlyRangeSwitch) {
            weeklyRangeSwitch.style.display = unit === "weekly" ? "inline-flex" : "none";
            dailyRangeSwitch.style.display = unit === "daily" ? "inline-flex" : "none";
            monthlyRangeSwitch.style.display = unit === "monthly" ? "inline-flex" : "none";
          }

          // 3. Toggle range buttons active state
          rangeButtons.forEach((button) => {
            const active = button.dataset.chartTrigger === range && button.dataset.chartUnit === unit;
            button.classList.toggle("is-active", active);
            button.setAttribute("aria-pressed", active ? "true" : "false");
            if (active && chartCaption) {
              chartCaption.textContent = button.dataset.rangeCaption || "";
            }
          });

          // 4. Toggle unit buttons active state
          unitButtons.forEach((button) => {
            const active = button.dataset.unitTrigger === unit;
            button.classList.toggle("is-active", active);
            button.setAttribute("aria-pressed", active ? "true" : "false");
          });

          // 5. Toggle SVGs
          chartSvgs.forEach((svg) => {
            const active = svg.dataset.chartRange === range && svg.dataset.chartUnit === unit;
            svg.classList.toggle("is-active", active);
            svg.style.display = active ? "block" : "none";
            svg.dataset.active = active ? "true" : "false";
          });

          // 6. Synchronize legend visibility states onto the active SVG
          const activeSvg = chartPanel.querySelector(`.line-chart[data-chart-range="${range}"][data-chart-unit="${unit}"]`);
          if (activeSvg) {
            chartPanel.querySelectorAll(".legend-item").forEach((legendItem) => {
              const series = legendItem.dataset.series;
              const isPressed = legendItem.getAttribute("aria-pressed") === "true";
              const selector = series === "total" 
                ? ".chart-line.total, .chart-area" 
                : `.chart-line[data-series="${series}"]`;
              
              activeSvg.querySelectorAll(selector).forEach((el) => {
                el.style.display = isPressed ? "" : "none";
              });
            });
          }
        };

        // Initialize default view
        activateChart(currentRange, currentUnit);

        chartPanel.addEventListener("click", (event) => {
          const unitButton = event.target.closest("[data-unit-trigger]");
          if (unitButton) {
            const newUnit = unitButton.dataset.unitTrigger;
            const targetRange = newUnit === "daily" ? "1m" : newUnit === "monthly" ? "all" : currentRange;
            activateChart(targetRange, newUnit);
            return;
          }

          const rangeButton = event.target.closest("[data-chart-trigger]");
          if (rangeButton) {
            const newRange = rangeButton.dataset.chartTrigger;
            activateChart(newRange, currentUnit);
            return;
          }

          const legendItem = event.target.closest(".legend-item");
          if (legendItem) {
            const series = legendItem.dataset.series;
            const isCurrentlyPressed = legendItem.getAttribute("aria-pressed") === "true";
            const newPressedState = !isCurrentlyPressed;
            
            legendItem.setAttribute("aria-pressed", newPressedState ? "true" : "false");
            
            const selector = series === "total" 
              ? ".chart-line.total, .chart-area" 
              : `.chart-line[data-series="${series}"]`;
            
            chartPanel.querySelectorAll(selector).forEach((el) => {
              el.style.display = newPressedState ? "" : "none";
            });
          }
        });

        // Initialize random tilts and scroll reveal for panels below daily dots
        const targetPanels = Array.from(
          document.querySelectorAll('.rank-grid .paper-panel, .insight-grid .paper-panel, .table-grid .paper-panel')
        );

        targetPanels.forEach((panel) => {
          // Random angle between -2.0deg and 2.0deg
          const tilt = (Math.random() * 4 - 2).toFixed(2);
          panel.style.setProperty('--tilt', `${tilt}deg`);
        });

        const revealObserver = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-revealed');
                revealObserver.unobserve(entry.target);
              }
            });
          },
          {
            threshold: 0.05,
            rootMargin: '0px 0px -20px 0px'
          }
        );

        targetPanels.forEach((panel) => {
          revealObserver.observe(panel);
        });

        // Scroll the daily dots heatmap to the rightmost (newest dates) on load
        const heatmap = document.querySelector(".daily-heatmap");
        if (heatmap) {
          heatmap.scrollLeft = heatmap.scrollWidth;
        }

        // Custom tooltip for daily dots: date, token usage and cost
        const tooltip = document.querySelector("[data-heat-tooltip]");
        if (heatmap && tooltip) {
          const tipDate = tooltip.querySelector("[data-tip-date]");
          const tipTokens = tooltip.querySelector("[data-tip-tokens]");
          const tipCost = tooltip.querySelector("[data-tip-cost]");

          const positionTooltip = (dot) => {
            const rect = dot.getBoundingClientRect();
            const tipRect = tooltip.getBoundingClientRect();
            let left = rect.left + rect.width / 2 - tipRect.width / 2;
            left = Math.max(8, Math.min(left, window.innerWidth - tipRect.width - 8));
            let top = rect.top - tipRect.height - 10;
            if (top < 8) {
              top = rect.bottom + 10;
            }
            tooltip.style.left = `${left}px`;
            tooltip.style.top = `${top}px`;
          };

          const showTooltip = (dot) => {
            tipDate.textContent = dot.dataset.date || "";
            tipTokens.textContent = dot.dataset.tokens || "";
            tipCost.textContent = dot.dataset.cost || "";
            tooltip.hidden = false;
            tooltip.classList.add("is-visible");
            positionTooltip(dot);
          };

          const hideTooltip = () => {
            tooltip.classList.remove("is-visible");
            tooltip.hidden = true;
          };

          heatmap.addEventListener("pointerover", (event) => {
            const dot = event.target.closest(".heat-dot");
            if (dot) showTooltip(dot);
          });
          heatmap.addEventListener("pointerout", (event) => {
            const dot = event.target.closest(".heat-dot");
            if (dot) hideTooltip();
          });
          heatmap.addEventListener("focusin", (event) => {
            const dot = event.target.closest(".heat-dot");
            if (dot) showTooltip(dot);
          });
          heatmap.addEventListener("focusout", hideTooltip);
          heatmap.addEventListener("scroll", hideTooltip, { passive: true });
        }
      })();
    </script>
  </body>
